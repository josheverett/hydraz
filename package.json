{
  "name": "hydraz",
  "version": "3.1.4",
  "description": "A Codex cloud harness for detached long-running coding goals",
  "type": "module",
  "packageManager": "pnpm@10.1.0",
  "bin": {
    "hydraz": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:sea": "bash scripts/build-sea.sh",
    "release:github": "bash scripts/release-github.sh",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "autonomous",
    "codex",
    "cloud",
    "agent"
  ],
  "author": "Josh Everett",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josheverett/hydraz.git"
  },
  "homepage": "https://github.com/josheverett/hydraz#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "esbuild": "^0.27.7",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}